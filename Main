    psExpState.currentExp++;
    psExpState.totalExp++;
    psExpSaveData(psExpState);
    psExpTriggerGainEffects();
    psExpCheckLvUp();
    psExpRender();
    const un = psExpGetUsername();
    await psLbPushEntry(un, psExpState.level, psExpState.totalExp);
    await psLbRender();
}, 60_000);

