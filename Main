n="1" max="6" value="2"><span class="ps_esp_slider_val" id="esp_box_thick_val">2</span></div></div><div class="ps_esp_section"><div class="ps_esp_section_label">Mob Filter</div><div class="ps_esp_filter_row"><span class="ps_esp_filter_label">Type</span><input class="ps_esp_filter_input" id="esp_filter_type" type="text" placeholder="e.g. Slime"></div><div class="ps_esp_filter_row"><span class="ps_esp_filter_label">ID</span><input class="ps_esp_filter_input" id="esp_filter_id" type="text" placeholder="exact ID"></div></div><div class="ps_esp_counter"><div class="ps_esp_count_pill" id="esp_player_counter">0 players</div><div class="ps_esp_count_pill" id="esp_mob_counter">0 mobs</div></div><button class="ps_esp_reset" id="esp_list_open_btn">Entity List</button><button class="ps_esp_reset" id="esp_reset_btn">Reset to defaults</button></div>`;espBox.insertBefore(makeHeader("ESP",()=>espBox.style.display="none"),espBox.firstChild);document.body.appendChild(espBox);
    const entityListPanel=document.createElement("div");entityListPanel.id="esp_entity_list_panel";entityListPanel.className="ps_box";entityListPanel.innerHTML=`<div id="esp_list_body"><div id="esp_list_empty">No entities detected</div></div><button id="esp_list_refresh_btn">Refresh</button>`;entityListPanel.insertBefore(makeHeader("Entity List",()=>entityListPanel.style.display="none"),entityListPanel.firstChild);document.body.appendChild(entityListPanel);
    function syncEntityListPanelBg(){const t=getTheme();entityListPanel.style.backgroundColor=t.hackBox;const hdr=entityListPanel.querySelector(".ps_header");if(hdr)hdr.style.backgroundColor=t.hackHeader;}

    const BLOCK_TYPES=[{id:"Floor",name:"Floor",w:32,h:32},{id:"Wall",name:"Wall",w:32,h:32},{id:"Airlock",name:"Airlock",w:128,h:32},{id:"ManualAirlock",name:"Manual Airlock",w:64,h:32},{id:"Bed",name:"Bed",w:64,h:32},{id:"Chair",name:"Chair",w:32,h:32},{id:"Furnace",name:"Furnace",w:32,h:64},{id:"Turret",name:"Turret",w:64,h:64},{id:"Workbench",name:"Workbench",w:64,h:32},{id:"StorageBox",name:"Storage Box",w:32,h:32},{id:"Generator",name:"Generator",w:64,h:64},{id:"Lamp",name:"Lamp",w:32,h:32},{id:"WoodFloor",name:"Wood Floor",w:32,h:32},{id:"SteelFloor",name:"Steel Floor",w:32,h:32},{id:"PlatedFloor",name:"Plated Floor",w:32,h:32},{id:"GreenFloor",name:"Green Floor",w:32,h:32},{id:"CarpetFloor",name:"Carpet Floor",w:32,h:32},{id:"TiledFloor",name:"Tiled Floor",w:32,h:32},{id:"Lattice",name:"Lattice",w:32,h:32},{id:"BlueWall",name:"Blue Wall",w:32,h:32},{id:"GreenWall",name:"Green Wall",w:32,h:32},{id:"IvoryWall",name:"Ivory Wall",w:32,h:32},{id:"RailTrack",name:"Rail Track",w:32,h:32},{id:"FlamethrowerTurret",name:"Flamethrower",w:64,h:64}];
    function getProtocolDef(){try{if(typeof Protocol!=='undefined'&&Protocol.definition)return Protocol.definition();}catch(e){}try{if(window.Protocol&&window.Protocol.definition)return window.Protocol.definition();}catch(e){}try{if(typeof game!=='undefined'&&game&&game.protocolDefinition)return game.protocolDefinition;}catch(e){}try{if(window.main&&window.main.protocol&&window.main.protocol.definition)return window.main.protocol.definition();}catch(e){}return null;}
    function bpGetNumericType(typeId){try{const def=getProtocolDef();if(def&&def.BuildingType){const val=def.BuildingType[typeId];if(val!=null)return val;}}catch(e){}try{const bt=game.buildingTypes||game.BuildingTypes;if(bt&&bt[typeId]!=null)return typeof bt[typeId]==='object'?(bt[typeId].type||bt[typeId].id):bt[typeId];}catch(e){}try{if(game.sector&&game.sector.buildings){for(const b of Object.values(game.sector.buildings)){if(!b)continue;const name=(b.constructor&&b.constructor.name)||b.typeName||'';if(name===typeId&&b.type!=null)return b.type;}}}catch(e){}return null;}
    function bpGetRequirements(typeId){try{const def=getProtocolDef();if(!def)return null;for(const g of['Walls','Floors','Buildings']){if(!def[g])continue;const entry=def[g][typeId];if(entry&&entry.requirements)return entry.requirements;if(entry&&entry.parent){const pk=entry.parent.split('.')[1];const p=def[g][pk];if(p&&p.requirements)return p.requirements;}}}catch(e){}return null;}
    function bpGetContainerId(){try{if(game.player.ship&&game.player.ship.id!=null)return game.player.ship.id;if(game.player.buildingContainer&&game.player.buildingContainer.id!=null)return game.player.buildingContainer.id;if(game.player.sector&&game.player.sector.id!=null)return game.player.sector.id;if(game.ship&&game.ship.id!=null)return game.ship.id;if(game.sector&&game.sector.id!=null)return game.sector.id;if(game.sector&&game.sector.buildings){for(const b of Object.values(game.sector.buildings)){if(b&&b.containerId!=null)return b.containerId;}}}catch(e){}return null;}
    const bp={mapMode:false,phantomVisible:true,selectedType:"Floor",phantoms:[],built:[],container:null,initialized:false,_raf:null};const BP_TILE=32;
    function bpScreenToWorld(sx,sy){try{const s=game.app.stage;return{wx:(sx-s.position.x)/s.scale.x,wy:(sy-s.position.y)/s.scale.y};}catch(e){}return{wx:sx,wy:sy};}
    function bpWorldToScreen(wx,wy){try{const s=game.app.stage;return{sx:wx*s.scale.x+s.position.x,sy:wy*s.scale.y+s.position.y};}catch(e){}return{sx:wx,sy:wy};}
    function bpWorldToGrid(wx,wy){return{gx:Math.floor(wx/BP_TILE),gy:Math.floor(wy/BP_TILE)};}
    function bpGridToServerXY(gx,gy,bW,bH){return{x:gx*BP_TILE+bW/2,y:gy*BP_TILE+bH/2};}
    function bpHasPhantom(gx,gy){return bp.phantoms.some(p=>p.gx===gx&&p.gy===gy);}
    function bpAddPhantom(gx,gy){if(bpHasPhantom(gx,gy))bp.phantoms=bp.phantoms.filter(p=>!(p.gx===gx&&p.gy===gy));else bp.phantoms.push({gx,gy,typeId:bp.selectedType});bpDrawPhantomsOnMap();bpUpdateStats();bpUpdateCostDisplay();}
    function bpRenderPhantoms(){if(!bp.container)return;bp.container.removeChildren();if(!bp.phantomVisible||bp.phantoms.length===0)return;const g=new PIXI.Graphics();bp.phantoms.forEach(p=>{const def=BLOCK_TYPES.find(b=>b.id===p.typeId)||BLOCK_TYPES[0];const wx=p.gx*BP_TILE,wy=p.gy*BP_TILE;const tl=bpWorldToScreen(wx,wy),br=bpWorldToScreen(wx+def.w,wy+def.h);const sx=tl.sx,sy=tl.sy,sw=br.sx-tl.sx,sh=br.sy-tl.sy;if(sw<=0||sh<=0)return;g.lineStyle(0);g.beginFill(0x44AAFF,0.28);g.drawRect(sx,sy,sw,sh);g.endFill();g.lineStyle(2,0xAADDFF,1.0);g.drawRect(sx,sy,sw,sh);g.lineStyle(0);g.beginFill(0xCCEEFF,0.95);[[sx,sy],[sx+sw,sy],[sx,sy+sh],[sx+sw,sy+sh]].forEach(([cx,cy])=>g.drawCircle(cx,cy,2.5));g.endFill();});bp.container.addChild(g);bp.phantoms.forEach(p=>{const def=BLOCK_TYPES.find(b=>b.id===p.typeId)||BLOCK_TYPES[0];const{sx,sy}=bpWorldToScreen(p.gx*BP_TILE+def.w/2,p.gy*BP_TILE+def.h/2);const t=new PIXI.Text(def.name,{fontFamily:'Arial',fontSize:11,fontWeight:'bold',fill:0xCCEEFF,stroke:0x001133,strokeThickness:2,align:'center'});t.anchor.set(0.5,0.5);t.position.set(sx,sy);bp.container.addChild(t);});}
    function bpTickLoop(){bp._raf=requestAnimationFrame(bpTickLoop);bpRenderPhantoms();}
    function bpInit(){const check=()=>{const ready=window.main&&window.main.isGameInitialized&&typeof game!=='undefined'&&game.app&&game.app.stage;if(ready){bp.container=new PIXI.Container();game.app.stage.addChild(bp.container);bp.initialized=true;bpTickLoop();}else setTimeout(check,300);};check();}
    let bpMapOverlayCanvas=null,bpMapOverlayCtx=null;
    function bpEnsureMapOverlay(){const ec=document.querySelector('#map_entity_canvas');if(!ec)return false;if(bpMapOverlayCanvas&&bpMapOverlayCanvas.isConnected){if(bpMapOverlayCanvas.width!==ec.width||bpMapOverlayCanvas.height!==ec.height){bpMapOverlayCanvas.width=ec.width;bpMapOverlayCanvas.height=ec.height;}return true;}const old=document.getElementById('bp_map_overlay');if(old)old.remove();bpMapOverlayCanvas=null;bpMapOverlayCtx=null;const parent=ec.parentElement;if(!parent)return false;if(window.getComputedStyle(parent).position==='static')parent.style.position='relative';bpMapOverlayCanvas=document.createElement('canvas');bpMapOverlayCanvas.id='bp_map_overlay';bpMapOverlayCanvas.width=ec.width;bpMapOverlayCanvas.height=ec.height;const ecs=window.getComputedStyle(ec);bpMapOverlayCanvas.style.width=ecs.width;bpMapOverlayCanvas.style.height=ecs.height;bpMapOverlayCanvas.style.top=ec.offsetTop+'px';bpMapOverlayCanvas.style.left=ec.offsetLeft+'px';parent.appendChild(bpMapOverlayCanvas);bpMapOverlayCtx=bpMapOverlayCanvas.getContext('2d');return true;}
    function bpDrawPhantomsOnMap(){if(!bpEnsureMapOverlay()||!bpMapOverlayCtx)return;let zm=2;try{if(typeof game!=='undefined'&&game&&game.mapMenu&&game.mapMenu.zoomMultiplier)zm=game.mapMenu.zoomMultiplier;}catch(e){}const ctx=bpMapOverlayCtx;ctx.clearRect(0,0,bpMapOverlayCanvas.width,bpMapOverlayCanvas.height);if(!bp.phantomVisible||bp.phantoms.length===0)return;bp.phantoms.forEach(p=>{const mapX=p.gx*zm,mapY=p.gy*zm;const def=BLOCK_TYPES.find(b=>b.id===p.typeId)||BLOCK_TYPES[0];const mapW=Math.max(zm,2)*(def.w/BP_TILE),mapH=Math.max(zm,2)*(def.h/BP_TILE);ctx.fillStyle='rgba(100,180,255,0.30)';ctx.fillRect(mapX,mapY,mapW,mapH);ctx.strokeStyle='rgba(80,160,255,0.95)';ctx.lineWidth=Math.max(1,zm*0.15);ctx.strokeRect(mapX+0.5,mapY+0.5,mapW-1,mapH-1);});}
    function bpSetupMapCanvasListener(){const ec=document.querySelector('#map_entity_canvas');if(!ec||ec._bpListenerAdded)return;ec._bpListenerAdded=true;ec.addEventListener('click',(e)=>{if(!bp.mapMode)return;let zm=2;try{if(typeof game!=='undefined'&&game&&game.mapMenu&&game.mapMenu.zoomMultiplier)zm=game.mapMenu.zoomMultiplier;}catch(err){}const rect=ec.getBoundingClientRect(),scaleX=ec.width/rect.width,scaleY=ec.height/rect.height;bpAddPhantom(Math.floor((e.clientX-rect.left)*scaleX/zm),Math.floor((e.clientY-rect.top)*scaleY/zm));e.stopPropagation();});}
    function bpUpdateMapCanvasCursor(){const ec=document.querySelector('#map_entity_canvas');if(!ec)return;ec.style.cursor=bp.mapMode?'crosshair':'';}
    setInterval(()=>{bpSetupMapCanvasListener();if(bp.phantoms.length>0){if(bpEnsureMapOverlay())bpDrawPhantomsOnMap();}},500);
    function bpUpdateCostDisplay(){const el=document.getElementById("bp_cost_display");if(!el)return;if(bp.phantoms.length===0){el.innerHTML='<span style="color:rgba(255,255,255,0.3)">No blocks planned</span>';return;}const totals={};bp.phantoms.forEach(p=>{const reqs=bpGetRequirements(p.typeId);if(!reqs)return;Object.entries(reqs).forEach(([item,qty])=>{totals[item]=(totals[item]||0)+qty;});});if(Object.keys(totals).length===0){el.innerHTML='<span style="color:rgba(255,255,255,0.3)">Requirements unknown</span>';return;}let html='';Object.entries(totals).forEach(([item,qty])=>{html+=`<div class="cost_row"><span>${item}</span><span>x${qty}</span></div>`;});el.innerHTML=html;}
    function bpSendBuild(gx,gy,typeId){try{const numericType=bpGetNumericType(typeId);if(numericType==null){showBpToast("Unknown type: "+typeId);return false;}const containerId=bpGetContainerId();if(containerId==null){showBpToast("Not in a world!");return false;}const def=BLOCK_TYPES.find(b=>b.id===typeId)||{w:32,h:32};const{x,y}=bpGridToServerXY(gx,gy,def.w,def.h);game.getSocketUtil().emit("Build",{type:numericType,angle:0,x,y,containerId});return true;}catch(e){showBpToast("Build error: "+e.message);return false;}}
    function bpBuild(){if(bp.phantoms.length===0){showBpToast("No blocks planned!");return;}const snapshot=[...bp.phantoms];snapshot.forEach((p,i)=>{setTimeout(()=>{bpSendBuild(p.gx,p.gy,p.typeId);},i*120);});setTimeout(()=>{snapshot.forEach(b=>bp.built.push(b));bp.phantoms=[];bpDrawPhantomsOnMap();bpUpdateStats();bpUpdateCostDisplay();showBpToast(`Build sent (${snapshot.length} block${snapshot.length!==1?'s':''})`);},snapshot.length*120+300);}
    function bpUndo(){if(bp.built.length===0){showBpToast("Nothing to undo");return;}showBpToast("Use your multi-tool to demolish manually");bp.built=[];bpUpdateStats();}
    function showBpToast(msg){let t=document.getElementById("bp_toast");if(!t){t=document.createElement("div");t.id="bp_toast";t.style.cssText="position:fixed;bottom:100px;left:50%;transform:translateX(-50%);z-index:11001;background:rgba(30,30,30,0.97);color:#fff;padding:9px 20px;border-radius:10px;font-size:13px;font-weight:bold;pointer-events:none;opacity:0;transition:opacity 0.2s;white-space:nowrap;";document.body.appendChild(t);}t.textContent=msg;t.style.opacity="1";clearTimeout(t._hideTimer);t._hideTimer=setTimeout(()=>{t.style.opacity="0";},2500);}
    bpInit();
    function bpOnCanvasClick(e){if(!bp.initialized)return;if(!blueprintBox||blueprintBox.style.display!=="flex")return;if(e.target&&e.target.closest&&e.target.closest('.ps_box'))return;try{const canvasEl=game.app.view;if(e.target!==canvasEl)return;const{wx,wy}=bpScreenToWorld(e.clientX,e.clientY);const{gx,gy}=bpWorldToGrid(wx,wy);bpAddPhantom(gx,gy);e.stopPropagation();e.preventDefault();}catch(err){}}
    document.addEventListener("click",bpOnCanvasClick,true);
    let bpBlockFilter='';
    function bpRenderBlockGrid(){const grid=document.getElementById("bp_block_grid");if(!grid)return;const filter=bpBlockFilter.toLowerCase(),filtered=filter?BLOCK_TYPES.filter(b=>b.name.toLowerCase().includes(filter)):BLOCK_TYPES;grid.innerHTML=filtered.map(b=>`<div class="bp_block_tile${bp.selectedType===b.id?' selected':''}" data-bid="${b.id}" title="${b.name} (${b.w}x${b.h}px)">${b.name}</div>`).join('');grid.querySelectorAll('.bp_block_tile').forEach(tile=>{tile.addEventListener('click',()=>{bp.selectedType=tile.dataset.bid;bpRenderBlockGrid();bpUpdateSelectedLabel();bpUpdateCostDisplay();});});}
    function bpUpdateSelectedLabel(){const lbl=document.getElementById("bp_selected_block_lbl");const block=BLOCK_TYPES.find(b=>b.id===bp.selectedType);if(lbl)lbl.textContent=block?`${block.name} (${block.w}x${block.h})`:'--';}
    function bpUpdateMapBtn(){const btn=document.getElementById("bp_map_btn");const hint=document.getElementById("bp_map_hint");if(btn){btn.textContent=bp.mapMode?'Map: ON':'Map';btn.classList.toggle("active",bp.mapMode);}if(hint)hint.classList.toggle("visible",bp.mapMode);bpUpdateMapCanvasCursor();}
    function bpUpdateVisBtn(){const btn=document.getElementById("bp_vis_btn");if(!btn)return;btn.textContent=bp.phantomVisible?'Visible: ON':'Visible: OFF';btn.classList.toggle("on",bp.phantomVisible);}
    function bpUpdateStats(){const c=document.getElementById("bp_phantom_count"),b=document.getElementById("bp_built_count");if(c){c.textContent=`${bp.phantoms.length} planned`;c.className='bp_stat_pill'+(bp.phantoms.length>0?' has_data':'');}if(b){b.textContent=`${bp.built.length} built`;b.className='bp_stat_pill'+(bp.built.length>0?' has_data':'');}}

    const blueprintBox=document.createElement("div");blueprintBox.id="ps_blueprint_box";blueprintBox.className="ps_box";
    blueprintBox.innerHTML=`<div class="ps_body"><div class="bp_section"><div class="bp_section_label">Actions</div><div class="bp_action_row"><button class="bp_action_btn" id="bp_map_btn">Map</button><button class="bp_action_btn go" id="bp_build_btn">Build</button><button class="bp_action_btn danger" id="bp_undo_btn">Undo</button></div><div id="bp_map_hint">Click map canvas to place blocks</div></div><div class="bp_section"><div class="bp_vis_row"><span class="bp_vis_label">Phantom overlay</span><button class="bp_vis_btn on" id="bp_vis_btn">Visible: ON</button></div></div><div class="bp_section"><div class="bp_section_label">Block Type &nbsp;<span id="bp_selected_block_lbl" style="font-weight:bold;color:rgba(255,255,255,0.85);text-transform:none;letter-spacing:0;">Floor (32x32)</span></div><input class="bp_block_search" id="bp_block_search" type="text" placeholder="Search blocks..."><div class="bp_block_grid" id="bp_block_grid"></div></div><div class="bp_section"><div class="bp_section_label">Materials needed</div><div id="bp_cost_display"><span style="color:rgba(255,255,255,0.3)">No blocks planned</span></div></div><div class="bp_section"><div class="bp_stat_row"><div class="bp_stat_pill" id="bp_phantom_count">0 planned</div><div class="bp_stat_pill" id="bp_built_count">0 built</div></div><div style="margin-top:5px;"><button class="bp_action_btn danger" id="bp_clear_btn" style="width:100%;font-size:11px;padding:4px 0;">Clear Phantoms</button></div></div></div>`;
