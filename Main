    async function fetchUserRecord(uid) {
        try {
            const res = await fetch(`https://matchmaker.junon.io/get_user?uid=${encodeURIComponent(uid)}`);
            if (!res.ok) return null;
            return await res.json();
        } catch(e) { return null; }
    }

    function cacheUid(uid) {
        if (uid) localStorage.setItem('ps_cached_uid', uid);
    }

    function getCachedUid() {
        try { if (typeof game !== 'undefined' && game.player && game.player.uid) return game.player.uid; } catch(e) {}
        for (const key of ['uid','user_uid','junonUid','ps_cached_uid']) {
            const v = localStorage.getItem(key);
            if (v && v.length > 4) return v;
        }
        try {
            const raw = localStorage.getItem('user') || localStorage.getItem('currentUser');
            if (raw) { const obj = JSON.parse(raw); if (obj && obj.uid) return obj.uid; }
        } catch(e) {}
        return null;
    }

    function findPlayerUidByUsername(username) {
        try {
            if (typeof game !== 'undefined' && game.sector && game.sector.players) {
                for (const p of Object.values(game.sector.players)) {
                    if (p && (p.username === username || p.name === username) && p.uid) return p.uid;
                }
            }
        } catch(e) {}
        return null;
    }

    setInterval(() => {
        try { if (typeof game !== 'undefined' && game.player && game.player.uid) cacheUid(game.player.uid); } catch(e) {}
    }, 2000);

