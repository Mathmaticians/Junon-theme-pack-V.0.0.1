    showLevel: true, showCount: true, showPercentage: true, showTotalTime: true,
    glowEnabled: true, shimmerEnabled: true, particlesEnabled: true,
    xpFlashEnabled: true, pulseOnGain: true,
    style: 'pill', position: 'right',
