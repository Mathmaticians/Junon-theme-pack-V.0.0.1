            nameConfirm:`rgba(${r},${g},${b},0.9)`, nameConfirmHover:`rgba(${r},${g},${b},1)`,
            toast:`rgba(${r},${g},${b},0.92)`, uiBg:`rgba(${r},${g},${b},0.45)`,
            hackBtn:`rgba(${d(r,20)},${d(g,20)},${d(b,20)},0.82)`,
            hackBtnHover:`rgba(${d(r,35)},${d(g,35)},${d(b,35)},1)`,
