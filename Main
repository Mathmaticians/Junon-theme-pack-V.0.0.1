                    const _a = _p.musicDataURL.split(',');
                    const _m = _a[0].match(/:(.*?);/)[1];
                    const _b = atob(_a[1]);
                    const _u = new Uint8Array(_b.length);
                    for (let _i = 0; _i < _b.length; _i++) _u[_i] = _b.charCodeAt(_i);
