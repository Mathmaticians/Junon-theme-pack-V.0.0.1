    function setStatus(text, state = '') {
        const dot  = document.getElementById('ps_sync_status_dot');
        const span = document.getElementById('ps_sync_status_text');
        if (dot)  { dot.className  = 'ps_sync_status_dot' + (state ? ' ' + state : ''); }
        if (span) { span.textContent = text; }
