                text-align:center;backdrop-filter:blur(8px);
                box-shadow:0 4px 20px rgba(0,0,0,0.5);
            `;
            document.body.appendChild(el);
        }
        el.textContent = msg;
        el.style.background = success
            ? 'rgba(40,160,80,0.95)'
            : 'rgba(200,60,60,0.95)';
        el.style.opacity = '1';
        clearTimeout(el._t);
        el._t = setTimeout(() => { el.style.opacity = '0'; }, 2600);
    }

    function buildSavePayload() {
        const payload = {
            v:    SYNC_VERSION,
            ts:   Date.now(),
            uid:  discordUser ? discordUser.id : 'guest',
            data: {},
        };

        PARASIDIEUM_KEYS.forEach(k => {
            const v = localStorage.getItem(k);
            if (v !== null) payload.data[k] = v;
        });

        const roboKey = localStorage.getItem('ps_robo_api_key');
        if (roboKey) payload.data['ps_robo_api_key'] = roboKey;

        try {
            const snap = {};
            if (typeof currentTheme    !== 'undefined') snap.currentTheme    = currentTheme;
            if (typeof musicEnabled    !== 'undefined') snap.musicEnabled    = musicEnabled;
            if (typeof bubblesEnabled  !== 'undefined') snap.bubblesEnabled  = bubblesEnabled;
            if (typeof borderEnabled   !== 'undefined') snap.borderEnabled   = borderEnabled;
            if (typeof extraEffectsEnabled !== 'undefined') snap.extraEffectsEnabled = extraEffectsEnabled;
            if (typeof originalMode    !== 'undefined') snap.originalMode    = originalMode;
            if (Object.keys(snap).length) {
                localStorage.setItem(INLINE_SETTINGS_KEY, JSON.stringify(snap));
                payload.data[INLINE_SETTINGS_KEY] = JSON.stringify(snap);
            }
        } catch (_) {}

        return payload;
    }

    function encodeSave(payload) {
        return btoa(unescape(encodeURIComponent(JSON.stringify(payload))));
    }

    function decodeSave(code) {
        try {
            return JSON.parse(decodeURIComponent(escape(atob(code.trim()))));
        } catch (_) {
            return null;
        }
    }

    function applySavePayload(payload) {
        if (!payload || !payload.data) return false;
        Object.entries(payload.data).forEach(([k, v]) => {
            localStorage.setItem(k, v);
        });
        return true;
    }

    function cloudSaveKey(uid) { return `${SAVE_PREFIX}cloud_${uid}`; }

    function cloudSave() {
        if (!discordUser) return false;
        const payload = buildSavePayload();
        try {
            localStorage.setItem(cloudSaveKey(discordUser.id), encodeSave(payload));
            lastSyncTime = Date.now();
            setStatus(`Saved · ${new Date().toLocaleTimeString()}`, 'ok');
            return true;
        } catch (e) {
            setStatus('Save failed — storage full?', 'error');
            return false;
        }
    }

    function cloudLoad() {
        if (!discordUser) return false;
        const raw = localStorage.getItem(cloudSaveKey(discordUser.id));
        if (!raw) { setStatus('No cloud save found', 'error'); return false; }
        const payload = decodeSave(raw);
        if (!payload) { setStatus('Corrupt save data', 'error'); return false; }
        if (applySavePayload(payload)) {
            setStatus(`Loaded · saved ${new Date(payload.ts).toLocaleTimeString()}`, 'ok');
            toast('Settings loaded! Refresh to apply all changes.');
            return true;
        }
        return false;
    }

    const _origSetItem = localStorage.setItem.bind(localStorage);
    localStorage.setItem = function (key, value) {
        _origSetItem(key, value);
        if (syncEnabled && discordUser && PARASIDIEUM_KEYS.includes(key)) {
            clearTimeout(localStorage._syncDebounce);
            localStorage._syncDebounce = setTimeout(cloudSave, 1500);
        }
    };

    function buildOAuthURL() {
        const params = new URLSearchParams({
            client_id:     DISCORD_CLIENT_ID,
            redirect_uri:  REDIRECT_URI,
            response_type: 'token',
            scope:         SCOPE,
        });
        return `https://discord.com/oauth2/authorize?${params}`;
    }

    async function fetchDiscordUser(accessToken) {
        const res = await fetch('https://discord.com/api/users/@me', {
            headers: { Authorization: `Bearer ${accessToken}` },
        });
        if (!res.ok) throw new Error('Discord API error ' + res.status);
        return res.json();
    }

    function getAvatarURL(user) {
        if (!user.avatar) return null;
        return `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png?size=64`;
    }

    function extractTokenFromHash() {
        const hash = window.location.hash.slice(1);
        const params = new URLSearchParams(hash);
        const token = params.get('access_token');
        const type  = params.get('token_type');
        if (token && type === 'Bearer') {
            history.replaceState(null, '', window.location.pathname + window.location.search);
            return token;
        }
        return null;
    }

    function storeSession(user, token) {
        localStorage.setItem(`${SAVE_PREFIX}session`, JSON.stringify({ user, token, ts: Date.now() }));
    }

    function loadSession() {
        try {
            const raw = localStorage.getItem(`${SAVE_PREFIX}session`);
            if (!raw) return null;
            const s = JSON.parse(raw);
            if (Date.now() - s.ts > 6 * 24 * 60 * 60 * 1000) return null;
            return s;
        } catch (_) { return null; }
    }

    function clearSession() {
        localStorage.removeItem(`${SAVE_PREFIX}session`);
    }

