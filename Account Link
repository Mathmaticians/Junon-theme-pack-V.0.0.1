        document.getElementById('ps_sync_header_title').className = '';
        syncBtn.classList.remove('linked');
        syncBtn.textContent = 'Discord Sync';
        setStatus('Not linked', '');

        document.getElementById('ps_sync_login_btn').addEventListener('click', () => {
            if (DISCORD_CLIENT_ID === 'YOUR_CLIENT_ID_HERE') {
                toast('Set your Discord Client ID in the script config first.', false);
                return;
            }
            window.open(buildOAuthURL(), '_self');
        });
    }

    function escHTML(s) {
        return String(s)
            .replace(/&/g,'&amp;')
            .replace(/</g,'&lt;')
            .replace(/>/g,'&gt;')
            .replace(/"/g,'&quot;');
    }

    async function init() {
        const freshToken = extractTokenFromHash();
        if (freshToken) {
            setStatus('Authenticating…', 'busy');
            try {
                const user = await fetchDiscordUser(freshToken);
                storeSession(user, freshToken);
                discordUser = user;
                renderLinkedUI(user);
                cloudSave();
                toast(`Linked as ${user.username}! Settings saved.`);
                syncBox.style.display = 'flex';
            } catch (e) {
                toast('Discord auth failed: ' + e.message, false);
                setStatus('Auth failed', 'error');
                renderUnlinkedUI();
            }
            return;
        }
        const session = loadSession();
        if (session) {
            try {
                const user = await fetchDiscordUser(session.token);
                storeSession(user, session.token);
                discordUser = user;
                renderLinkedUI(user);
                setStatus(`Auto-restored · ${user.username}`, 'ok');
            } catch (_) {
                clearSession();
                renderUnlinkedUI();
            }
        } else {
            renderUnlinkedUI();
        }
    }
    if (document.body) {
        init();
    } else {
        document.addEventListener('DOMContentLoaded', init);
    }

})();
