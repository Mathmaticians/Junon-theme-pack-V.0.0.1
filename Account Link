            syncEnabled = !syncEnabled;
            autoToggle.textContent = syncEnabled ? 'ON' : 'OFF';
            autoToggle.className = 'ps_sync_toggle' + (syncEnabled ? ' on' : '');
            toast(syncEnabled ? 'Auto-save enabled' : 'Auto-save disabled');
        });

        document.getElementById('ps_sync_save_btn').addEventListener('click', () => {
            setStatus('Saving…', 'busy');
            setTimeout(() => {
                const ok = cloudSave();
                if (ok) toast('Saved to this device!');
