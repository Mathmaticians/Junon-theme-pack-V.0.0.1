            setStatus('Export code generated', 'ok');
        });

        document.getElementById('ps_sync_copy_btn').addEventListener('click', () => {
            const area = document.getElementById('ps_sync_code_area');
            if (!area.value.trim()) {
                toast('Generate an export code first.', false);
                return;
            }
            navigator.clipboard.writeText(area.value.trim())
                .then(() => toast('Copied to clipboard!'))
                .catch(() => { area.select(); document.execCommand('copy'); toast('Copied!'); });
        });

        document.getElementById('ps_sync_import_apply_btn').addEventListener('click', () => {
            const raw = document.getElementById('ps_sync_code_area').value.trim();
            if (!raw) { toast('Paste an import code first.', false); return; }
            const payload = decodeSave(raw);
            if (!payload) { toast('Invalid code.', false); setStatus('Invalid import code', 'error'); return; }
            if (!confirm('Apply this import? Your current settings will be replaced on next page refresh.')) return;
            if (applySavePayload(payload)) {
                toast('Imported! Refresh to apply all changes.');
                setStatus(`Imported save from ${new Date(payload.ts).toLocaleString()}`, 'ok');
            } else {
                toast('Import failed.', false);
            }
        });

        document.getElementById('ps_sync_wipe_btn').addEventListener('click', () => {
            if (!confirm('Delete your cloud save on this device? (Your actual settings are NOT deleted, only the backup copy.)')) return;
            localStorage.removeItem(cloudSaveKey(user.id));
            toast('Cloud save wiped.');
            setStatus('Cloud save deleted', 'error');
        });
    }

