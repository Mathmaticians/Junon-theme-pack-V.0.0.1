    (function makeSyncDraggable() {
        const header = document.getElementById('ps_sync_header');
        let dragging = false, ox, oy;
        header.addEventListener('mousedown', e => {
            if (e.target.id === 'ps_sync_close') return;
            dragging = true;
            ox = e.clientX - syncBox.getBoundingClientRect().left;
            oy = e.clientY - syncBox.getBoundingClientRect().top;
            syncBox.style.bottom = 'auto';
            e.preventDefault();
        });
        document.addEventListener('mousemove', e => {
            if (!dragging) return;
            syncBox.style.left = (e.clientX - ox) + 'px';
            syncBox.style.top  = (e.clientY - oy) + 'px';
        });
        document.addEventListener('mouseup', () => { dragging = false; });
    })();

    document.getElementById('ps_sync_close').addEventListener('click', () => {
        syncBox.style.display = 'none';
    });

